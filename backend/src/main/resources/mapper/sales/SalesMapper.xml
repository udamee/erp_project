<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.erp.backend.sales.mapper.SalesMapper">
    <!-- 매출청구 목록/조건 조회 -->
    <select id="findAllSalesInvoices"
            parameterType="map"
            resultType="com.erp.backend.sales.vo.SalesInvoiceVO">
        SELECT *
        FROM SALES_INVOICE
        WHERE 1 = 1
        <if test="status != null and status != ''">
            AND STATUS = #{status}
        </if>
        <if test="startDate != null and startDate != ''">
            AND ISSUE_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND ISSUE_DATE &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>

        ORDER BY SALES_INVOICE_ID DESC
    </select>

    <!-- 매입청구 목록/조건 조회 -->
    <select id="findAllPurchaseInvoices"
            parameterType="map"
            resultType="com.erp.backend.sales.vo.PurchaseInvoiceVO">
        SELECT *
        FROM PURCHASE_INVOICE
        WHERE 1 = 1
        <if test="status != null and status != ''">
            AND STATUS = #{status}
        </if>
        <if test="startDate != null and startDate != ''">
            AND ISSUE_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND iSSUE_DATE &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>

        ORDER BY PURCHASE_INVOICE_ID DESC
    </select>

    <!-- 매출채권/미수금 목록/조건 조회 -->
    <select id="findAllAccountReceivables"
            parameterType="map"
            resultType="com.erp.backend.sales.vo.AccountReceivableVO">
        SELECT *
        FROM ACCOUNT_RECEIVABLE
        WHERE 1 = 1
        <if test="status != null and status != ''">
            AND STATUS = #{status}
        </if>
        <if test="startDate != null and startDate != ''">
            AND DUE_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND DUE_DATE &gt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>
        ORDER BY AR_ID DESC
    </select>

    <!-- 매입채무/미지급금 목록/조건 조회 -->
    <select id="findAllAccountPayables"
            parameterType="map"
            resultType="com.erp.backend.sales.vo.AccountPayableVO">
        SELECT *
        FROM ACCOUNT_PAYABLE
        WHERE 1 = 1
        <if test="status != null and status != ''">
            AND STATUS = #{status}
        </if>
        <if test="startDate != null and startDate != ''">
            AND DUE_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND DUE_DATE &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>

        ORDER BY AP_ID DESC
    </select>

    <!-- 수금내역 조회 -->
    <select id="findAllPayments"
            resultType="com.erp.backend.sales.vo.PaymentVO">
        SELECT *
        FROM PAYMENT
        WHERE 1 = 1
        <if test="startDate != null and startDate != ''">
            AND PAYMENT_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND PAYMENT_DATE &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>
        ORDER BY PAYMENT_ID DESC
    </select>

    <!-- 손익정산 조회 -->
    <select id="findAllSettlements"
            parameterType="map"
            resultType="com.erp.backend.sales.vo.SettlementVO">
        SELECT *
        FROM SETTLEMENT
        WHERE 1 = 1
        <if test="startDate != null and startDate != ''">
            AND START_DATE &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null and endDate != ''">
            AND END_DATE &gt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
        </if>
        ORDER BY SETTLEMENT_ID DESC
    </select>

    <!-- 매출청구 상세 조회 -->
    <select id="findSalesInvoiceById"
            resultType="com.erp.backend.sales.vo.SalesInvoiceVO">
        SELECT *
        FROM SALES_INVOICE
        WHERE SALES_INVOICE_ID = #{salesInvoiceId}
    </select>

    <!-- 매입청구 상세 조회 -->
    <select id="findPurchaseInvoiceById"
            resultType="com.erp.backend.sales.vo.PurchaseInvoiceVO">
        SELECT *
        FROM PURCHASE_INVOICE
        WHERE PURCHASE_INVOICE_ID = #{purchaseInvoiceId}
    </select>

    <!-- 매출채권/미수금 상세 조회 -->
    <select id="findAccountReceivableById"
            resultType="com.erp.backend.sales.vo.AccountReceivableVO">
        SELECT *
        FROM ACCOUNT_RECEIVABLE
        WHERE AR_ID = #{arId}
    </select>

    <!-- 매입채무/미지급금 상세 조회 -->
    <select id="findAccountPayableById"
            resultType="com.erp.backend.sales.vo.AccountPayableVO">
        SELECT *
        FROM ACCOUNT_PAYABLE
        WHERE AP_ID = #{apId}
    </select>

    <!-- 수금내역 상세 조회 -->
    <select id="findPaymentById"
            resultType="com.erp.backend.sales.vo.PaymentVO">
        SELECT *
        FROM PAYMENT
        WHERE PAYMENT_ID = #{paymentId}
    </select>

    <!-- 손익정산 상세 조회 -->
    <select id="findSettlementById"
            resultType="com.erp.backend.sales.vo.SettlementVO">
        SELECT *
        FROM SETTLEMENT
        WHERE SETTLEMENT_ID = #{settlementId}
    </select>

    <!-- 매출청구 등록 -->
    <insert id="insertSalesInvoice"
            parameterType="com.erp.backend.sales.vo.SalesInvoiceVO">
        <selectKey keyProperty="salesInvoiceId"
                   resultType="int"
                   order="BEFORE">
            SELECT SALES_INVOICE_SEQ.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO SALES_INVOICE (
            SALES_INVOICE_ID,
            SO_ID,
            CUSTOMER_ID,
            ISSUE_DATE,
            TOTAL_AMOUNT,
            STATUS,
            CREATED_AT
        ) VALUES (
            #{salesInvoiceId},
            #{soId},
            #{customerId},
            #{issueDate},
            #{totalAmount},
            #{status},
            SYSDATE
        )
    </insert>

    <!-- 매출채권(미수금) 등록 -->
    <insert id="insertAccountReceivable"
            parameterType="com.erp.backend.sales.vo.AccountReceivableVO">
        INSERT INTO ACCOUNT_RECEIVABLE (
            AR_ID,
            CUSTOMER_ID,
            SALES_INVOICE_ID,
            TOTAL_AMOUNT,
            PAID_AMOUNT,
            REMAIN_AMOUNT,
            DUE_DATE,
            STATUS,
            CREATED_AT
        ) VALUES (
            ACCOUNT_RECEIVABLE_SEQ.NEXTVAL,
            #{customerId},
            #{salesInvoiceId},
            #{totalAmount},
            #{paidAmount},
            #{remainAmount},
            #{dueDate},
            #{status},
            SYSDATE
        )
    </insert>

    <!-- 수금 처리 -->
    <insert id="insertPayment"
            parameterType="com.erp.backend.sales.vo.PaymentVO">
        INSERT INTO PAYMENT (
            PAYMENT_ID,
            AR_ID,
            CUSTOMER_ID,
            PAYMENT_DATE,
            PAYMENT_AMOUNT,
            PAYMENT_TYPE,
            CREATED_BY,
            CREATED_AT
        ) VALUES (
            PAYMENT_SEQ.NEXTVAL,
            #{arId},
            #{customerId},
            #{paymentDate},
            #{paymentAmount},
            #{paymentType},
            #{createdBy},
            SYSDATE
        )
    </insert>

    <!-- 미수금 차감 -->
    <update id="updateAccountReceivablePayment"
            parameterType="com.erp.backend.sales.vo.PaymentVO">
        UPDATE ACCOUNT_RECEIVABLE
        SET
            PAID_AMOUNT = PAID_AMOUNT + #{paymentAmount},
            REMAIN_AMOUNT = REMAIN_AMOUNT - #{paymentAmount},
            STATUS = CASE
                WHEN REMAIN_AMOUNT - #{paymentAmount} = 0 THEN 'PAID'
                ELSE 'PARTIAL'
            END
        WHERE AR_ID = #{arId}
    </update>
</mapper>